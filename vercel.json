{
    "version": 2,
    "functions": {
        "api/main.py": {
            "runtime": "python3.12"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/health",
            "destination": "/api/main.py"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}