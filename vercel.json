{
    "version": 2,
    "functions": {
        "api/main.py": {
            "runtime": "python@3.11"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/health",
            "destination": "/api/main.py"
        }
    ]
}