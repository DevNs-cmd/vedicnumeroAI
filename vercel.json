{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/health",
      "destination": "api/main.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.12",
    "ENABLE_TEST_ROUTES": "0",
    "CORS_ORIGINS": "*"
  }
}