{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/health",
      "destination": "api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "env": {
    "CORS_ORIGINS": "*",
    "ENABLE_TEST_ROUTES": "0"
  }
}